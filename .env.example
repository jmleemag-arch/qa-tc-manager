DATABASE_URL="file:./dev.db"
PORT=3001

# Redmine integration (leave empty to use mock mode)
REDMINE_URL="https://redmine.example.com"
REDMINE_API_KEY="your-api-key"
REDMINE_PROJECT_ID="qa-manager"
REDMINE_MOCK="true"

# Optional Redmine custom field for menu/category
REDMINE_MENU_CUSTOM_FIELD_ID=""

# Optional priority id mapping
REDMINE_PRIORITY_LOW_ID=1
REDMINE_PRIORITY_NORMAL_ID=2
REDMINE_PRIORITY_HIGH_ID=3
REDMINE_PRIORITY_URGENT_ID=4
